APP_NAME=AI Assistants Backend
API_PREFIX=/api/v1
DEBUG=true

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=ai_backend
POSTGRES_PASSWORD=ai_backend
POSTGRES_DB=ai_backend
DATABASE_URL=

REDIS_URL=redis://localhost:6379/0
QUEUE_NAMES=default,documents,integrations,deploy
PROCESS_DOCUMENTS_ASYNC=false
ENFORCE_BILLING_LIMITS=false
STORAGE_ROOT=storage
INTEGRATION_SECRET_KEY=change-integration-secret

PUBLIC_API_URL=http://localhost:8000
PUBLIC_FRONTEND_URL=http://localhost:5173
PUBLIC_WIDGET_URL=http://localhost:5173/widget.js

S3_ENDPOINT_URL=
S3_BUCKET_NAME=ai-assistants
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=assistant_chunks
SENTRY_DSN=

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=900
OPENAI_TEMPERATURE=0.3

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

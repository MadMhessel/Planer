APP_NAME=AI Assistants Backend
API_PREFIX=/api/v1
DEBUG=false

POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_USER=ai_backend
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=ai_backend
DATABASE_URL=

REDIS_URL=redis://redis:6379/0
QUEUE_NAMES=default,documents,integrations,deploy
PROCESS_DOCUMENTS_ASYNC=true
ENFORCE_BILLING_LIMITS=true

STORAGE_ROOT=/data/storage
INTEGRATION_SECRET_KEY=replace-with-long-random-secret

PUBLIC_API_URL=https://testpromo.lab.denis-dev.ru
PUBLIC_FRONTEND_URL=https://testpromo.lab.denis-dev.ru
PUBLIC_WIDGET_URL=https://testpromo.lab.denis-dev.ru/widget.js
CORS_ORIGINS=https://testpromo.lab.denis-dev.ru

S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET_NAME=ai-assistants
S3_ACCESS_KEY_ID=replace-with-minio-user
S3_SECRET_ACCESS_KEY=replace-with-minio-password
S3_REGION=auto

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=assistant_chunks
SENTRY_DSN=

OPENAI_API_KEY=replace-with-openai-key
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=900
OPENAI_TEMPERATURE=0.3

YOOKASSA_SHOP_ID=replace-with-shop-id
YOOKASSA_SECRET_KEY=replace-with-secret-key
YOOKASSA_WEBHOOK_SECRET=replace-with-webhook-secret

SMTP_HOST=replace-with-smtp-host
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=noreply@testpromo.lab.denis-dev.ru
SMTP_FROM_NAME=AI Ассистенты
SMTP_USE_TLS=true

NOTION_CLIENT_ID=replace-with-notion-client-id
NOTION_CLIENT_SECRET=replace-with-notion-client-secret
SLACK_CLIENT_ID=replace-with-slack-client-id
SLACK_CLIENT_SECRET=replace-with-slack-client-secret
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
HUBSPOT_CLIENT_ID=replace-with-hubspot-client-id
HUBSPOT_CLIENT_SECRET=replace-with-hubspot-client-secret

JWT_SECRET_KEY=replace-with-long-random-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

MINIO_ROOT_USER=replace-with-minio-user
MINIO_ROOT_PASSWORD=replace-with-minio-password
